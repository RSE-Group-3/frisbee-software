<?xml version="1.0" ?>
<robot name="fb_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Base link -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.635 0.846 0.48"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.635 0.846 0.48"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.1" iyy="0.1" izz="0.1"
               ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>
  </link>

  <!-- Wheel macro -->
  <xacro:macro name="wheel" params="name x y z driven">

    <link name="${name}_link">
      <visual>
        <geometry>
          <cylinder radius="0.09" length="0.05"/>
        </geometry>
        <material name="black">
          <color rgba="0 0 0 1"/>
        </material>
        <origin rpy="1.5708 0 0" xyz="0 0 0"/>
      </visual>

      <collision>
        <geometry>
          <cylinder radius="0.09" length="0.05"/>
        </geometry>
        <origin rpy="1.5708 0 0" xyz="0 0 0"/>

        <surface>
          <friction>
            <ode>

              <!-- Driven wheels (rear) -->
              <xacro:if value="${driven}">
                <mu>1.0</mu>
                <mu2>0.1</mu2>
              </xacro:if>

              <!-- Passive wheels (front) -->
              <xacro:unless value="${driven}">
                <mu>0.8</mu>
                <mu2>0.01</mu2>
              </xacro:unless>

              <!-- Rolling direction -->
              <fdir1>1 0 0</fdir1>

            </ode>
          </friction>
        </surface>

      </collision>

      <inertial>
        <mass value="0.2"/>
        <origin xyz="0 0 0"/>
        <inertia ixx="0.001" iyy="0.001" izz="0.001"
                 ixy="0.0" ixz="0.0" iyz="0.0"/>
      </inertial>
    </link>

    <!-- Joint -->
    <joint name="${name}_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${name}_link"/>
      <origin xyz="${x} ${y} ${z}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit effort="30.0" velocity="20.0"/>
    </joint>

    <!-- Transmission (only for driven wheels) -->
    <xacro:if value="${driven}">
      <transmission name="${name}_trans">
        <type>transmission_interface/SimpleTransmission</type>
        <joint name="${name}_joint">
          <hardwareInterface>hardware_interface/VelocityJointInterface</hardwareInterface>
        </joint>
        <actuator name="${name}_motor">
          <hardwareInterface>hardware_interface/VelocityJointInterface</hardwareInterface>
          <mechanicalReduction>1</mechanicalReduction>
        </actuator>
      </transmission>
    </xacro:if>

  </xacro:macro>

  <!-- Wheels -->
  <xacro:wheel name="front_left_wheel"  x="0.191"  y="0.454" z="-0.24" driven="false"/>
  <xacro:wheel name="front_right_wheel" x="0.191"  y="-0.454" z="-0.24" driven="false"/>
  <xacro:wheel name="rear_left_wheel"   x="-0.135" y="0.454" z="-0.24" driven="true"/>
  <xacro:wheel name="rear_right_wheel"  x="-0.135" y="-0.454" z="-0.24" driven="true"/>

  <link name="collector_camera_link">
    <visual>
      <geometry>
        <box size="0.05 0.05 0.05"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <joint name="collector_camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="collector_camera_link"/>
    <origin xyz="0.315 0.0 0.5" rpy="0 0.7 0"/>
  </joint>

  <link name="collector_camera_optical_frame"/>

  <joint name="collector_camera_optical_joint" type="fixed">
    <parent link="collector_camera_link"/>
    <child link="collector_camera_optical_frame"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <gazebo reference="collector_camera_link">
    <sensor name="collector_camera_sensor" type="camera">
      <update_rate>30</update_rate>
      <camera>
        <horizontal_fov>1.30</horizontal_fov>
        <image>
          <width>320</width>
          <height>240</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>100</far>
        </clip>
      </camera>

      <plugin name="gazebo_ros_camera" filename="libgazebo_ros_camera.so">
        <ros>
          <namespace>/camera</namespace>
          <remapping>image_raw:=image_raw</remapping>
        </ros>
        <camera_name>collector</camera_name>
        <frame_name>collector_camera_optical_frame</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- ros2_control -->
  <ros2_control name="fb_robot" type="system">
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>

    <joint name="rear_left_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="rear_right_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <!-- Gazebo plugin -->
  <gazebo>
    <plugin name="gazebo_ros2_control" filename="libgazebo_ros2_control.so">
      <parameters>$(arg controller_config)</parameters>
    </plugin>
  </gazebo>

</robot>